{
  "name": "@workspace/financial-frontend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "dev": "NG_CLI_ANALYTICS=false ng serve --host 0.0.0.0 --port $PORT --proxy-config proxy.conf.json",
    "build": "NG_CLI_ANALYTICS=false ng build",
    "watch": "NG_CLI_ANALYTICS=false ng build --watch --configuration development",
    "start": "NG_CLI_ANALYTICS=false ng serve --host 0.0.0.0 --port $PORT --proxy-config proxy.conf.json --allowed-hosts all"
  },
  "dependencies": {
    "@angular/animations": "^18.2.0",
    "@angular/cdk": "^18.2.0",
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "@angular/material": "^18.2.0",
    "@angular/platform-browser": "^18.2.0",
    "@angular/platform-browser-dynamic": "^18.2.0",
    "@angular/router": "^18.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.0",
    "@angular/cli": "^18.2.0",
    "@angular/compiler-cli": "^18.2.0",
    "typescript": "~5.5.0"
  }
}
